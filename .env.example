# OrderFood Docker 环境变量配置
# 复制此文件为 .env 并修改配置

# ==================== 数据库配置 ====================
# MySQL root密码（必须修改！）
MYSQL_ROOT_PASSWORD=your-strong-password-here

# ==================== JWT配置 ====================
# JWT密钥（必须修改！用于用户认证）
JWT_SECRET=your-super-secret-jwt-key-change-this

# ==================== 可选配置 ====================
# 以下配置有默认值，可根据需要修改

# 数据库连接池
# DB_MAX_IDLE=10
# DB_MAX_OPEN=100

# JWT过期时间（小时）
# JWT_EXPIRE_HOURS=168

# 图片最大大小（字节）
# IMAGE_MAX_SIZE=5242880
